# Eddie MCP Service Configuration

# OAuth2 Configuration (required for authentication)
OAUTH2_CLIENT_ID=your_client_id_here
OAUTH2_USERNAME=your_username_here
OAUTH2_PASSWORD=your_password_here

# API Configuration (optional - defaults to staging)
EDITO_API_BASE=https://api.staging.edito.eu/data
OAUTH2_TOKEN_URL=https://auth.staging.edito.eu/auth/realms/datalab/protocol/openid-connect/token

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
REQUEST_TIMEOUT=30
